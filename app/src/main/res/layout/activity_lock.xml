<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/header_gradient"
    android:orientation="vertical">

    <!-- Top section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Lock icon -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_lock_lock"
            android:tint="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Receipt Manager"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter PIN to unlock"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- PIN dots row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/dot1"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_margin="10dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:id="@+id/dot2"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_margin="10dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:id="@+id/dot3"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_margin="10dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:id="@+id/dot4"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_margin="10dp"
                android:background="@drawable/pin_dot_empty" />

        </LinearLayout>

        <!-- Error text -->
        <TextView
            android:id="@+id/tvPinError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF5252"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Fingerprint button -->
        <ImageButton
            android:id="@+id/btnFingerprint"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/circle_bg_image"
            android:src="@android:drawable/ic_partial_secure"
            android:tint="@color/colorPrimary"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Keypad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#22000000"
        android:padding="16dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn1" style="@style/PinButton" android:text="1"/>
            <Button android:id="@+id/btn2" style="@style/PinButton" android:text="2"/>
            <Button android:id="@+id/btn3" style="@style/PinButton" android:text="3"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn4" style="@style/PinButton" android:text="4"/>
            <Button android:id="@+id/btn5" style="@style/PinButton" android:text="5"/>
            <Button android:id="@+id/btn6" style="@style/PinButton" android:text="6"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn7" style="@style/PinButton" android:text="7"/>
            <Button android:id="@+id/btn8" style="@style/PinButton" android:text="8"/>
            <Button android:id="@+id/btn9" style="@style/PinButton" android:text="9"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <View android:layout_width="80dp" android:layout_height="80dp"
                android:layout_margin="8dp"/>
            <Button android:id="@+id/btn0" style="@style/PinButton" android:text="0"/>
            <ImageButton
                android:id="@+id/btnBackspace"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_margin="8dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_input_delete"
                android:tint="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>